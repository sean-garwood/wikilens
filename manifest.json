{
  "name": "wikilens",
  "browser_specific_settings": {
    "gecko": {
      "id": "@wikilens",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "version": "1.0.2",
  "description": "Grab Wikipedia summaries from highlighted text",
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["src/show.service.js", "content-script.js"]
    }
  ],
  "icons": {
    "48": "images/mona-lisa.png",
    "128": "images/icon-128.png"
  },
  "manifest_version": 3
}
