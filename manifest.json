{
  "name": "wikilens",
  "version": "1.0.0",
  "description": "Grab Wikipedia summaries from highlighted text",
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content-script.js"]
    }
  ],
  "permissions": ["webRequest"],
  "icons": {
    "48": "images/mona-lisa.png",
    "128": "images/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["tooltip.html"],
      "matches": ["*://*/*"]
    }
  ],
  "manifest_version": 3
}
