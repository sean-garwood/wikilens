{
  "name": "wikilens",
  "version": "1.0.0",
  "description": "Grab Wikipedia summaries from highlighted text",
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["src/show.service.js", "content-script.js"]
    }
  ],
  "icons": {
    "48": "images/mona-lisa.png",
    "128": "images/icon-128.png"
  },
  "manifest_version": 3
}
